        "matter_allow_setup_payload": {
          "$ref": "#/$defs/booleanFlag",
          "description": "Allows Matter setup payload access."
        },
        "sandbox": {
          "$ref": "#/$defs/sandboxConfig"
        },
        "extra": {
          "type": "object",
          "default": {},
          "description": "Raw entitlement keys not modeled directly by Orbit. Keys generated from first-class fields cannot be overridden here.",
          "additionalProperties": {
            "$ref": "#/$defs/plistValue"
          }
        }
      }
    },
    "stringArray": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "devProdString": {
      "type": "string",
      "enum": ["development", "production"]
    },
    "nsServiceEntry": {
      "type": "object",
      "description": "Single macOS service definition from the `NSServices` array.",
      "properties": {
        "NSPortName": {
          "type": "string",
          "description": "Incoming service port name."
        },
        "NSMessage": {
          "type": "string",
          "description": "Instance method name invoked for the service."
        },
        "NSSendFileTypes": {
          "$ref": "#/$defs/stringArray",
          "description": "UTI file types accepted by the service."
        },
        "NSSendTypes": {
          "$ref": "#/$defs/stringArray",
          "description": "Pasteboard types accepted by the service."
        },
        "NSServiceDescription": {
          "type": "string",
          "description": "Localized description presented to users."
        },
        "NSRequiredContext": {
          "$ref": "#/$defs/plistValue",
          "description": "Conditions that control whether the service is available."
        },
        "NSRestricted": {
          "type": "boolean",
          "description": "Whether sandboxed apps are prevented from invoking the service."
        },
        "NSReturnTypes": {
          "$ref": "#/$defs/stringArray",
          "description": "Pasteboard types returned by the service."
        },
        "NSMenuItem": {
          "type": "object",
          "description": "Service menu item configuration.",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": {
        "$ref": "#/$defs/plistValue"
      }
    },
    "nsUbiquitousContainerSettings": {
      "type": "object",
      "description": "Settings for a single iCloud Drive container.",
      "properties": {
        "NSUbiquitousContainerIsDocumentScopePublic": {
          "type": "boolean",
          "description": "Whether iCloud Drive should expose the container contents publicly."
        },
        "NSUbiquitousContainerName": {
          "type": "string",
          "description": "Display name used for the container in iCloud Drive."
        },
        "NSUbiquitousContainerSupportedFolderLevels": {
          "type": "string",
          "description": "Maximum nesting level allowed in the container's Documents directory.",
          "enum": ["None", "One", "Any"]
        }
      },
      "additionalProperties": {
        "$ref": "#/$defs/plistValue"
      }
    },
    "booleanFlag": {
      "type": "boolean",
      "default": false
    },
    "sandboxConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "network": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "enum": ["client", "server"]
          }
        },
        "files": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "enum": ["user-selected.read-only", "user-selected.read-write"]
          }
        }
      }
    },
    "pushConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["environment"],
      "properties": {
        "environment": {
          "type": "string",
          "enum": ["development", "production"]
        },
        "credential": {
          "type": "string",
          "enum": ["auth-key", "certificate"],
          "default": "auth-key"
        },
        "broadcast": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "entryConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["class"],
      "properties": {
        "class": {
          "type": "string",
          "minLength": 1,
          "description": "Objective-C runtime entry class."
        }
      }
    },
    "extensionConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "sources", "entry"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["packet-tunnel", "widget", "share", "safari", "safari-web"]
        },
        "platforms": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/applePlatform"
          }
        },
        "sources": {
          "$ref": "#/$defs/pathArray"
        },
        "resources": {
          "$ref": "#/$defs/pathArray"
        },
        "dependencies": {
          "$ref": "#/$defs/dependencies"
        },
        "info": {
          "$ref": "#/$defs/infoManifest"
        },
        "entitlements": {
          "$ref": "#/$defs/entitlementsManifest"
        },
        "push": {
          "$ref": "#/$defs/pushConfig"
        },
        "entry": {
          "$ref": "#/$defs/entryConfig"
        }
      }
    },
    "watchConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["extension"],
      "properties": {
        "sources": {
          "$ref": "#/$defs/pathArray"
        },
        "resources": {
          "$ref": "#/$defs/pathArray"
        },
        "dependencies": {
          "$ref": "#/$defs/dependencies"
        },
        "info": {
          "$ref": "#/$defs/infoManifest"
        },
        "entitlements": {
          "$ref": "#/$defs/entitlementsManifest"
        },
        "extension": {
          "$ref": "#/$defs/watchExtensionConfig"
        }
      }
    },
    "watchExtensionConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sources", "entry"],
      "properties": {
        "sources": {
          "$ref": "#/$defs/pathArray"
        },
        "resources": {
          "$ref": "#/$defs/pathArray"
        },
        "dependencies": {
          "$ref": "#/$defs/dependencies"
        },
        "info": {
          "$ref": "#/$defs/infoManifest"
        },
        "entitlements": {
          "$ref": "#/$defs/entitlementsManifest"
        },
        "entry": {
          "$ref": "#/$defs/entryConfig"
        }
      }
    },
    "appClipConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sources"],
      "properties": {
        "sources": {
          "$ref": "#/$defs/pathArray"
        },
        "resources": {
          "$ref": "#/$defs/pathArray"
        },
        "dependencies": {
          "$ref": "#/$defs/dependencies"
        },
        "info": {
          "$ref": "#/$defs/infoManifest"
        },
        "entitlements": {
          "$ref": "#/$defs/entitlementsManifest"
        },
        "push": {
          "$ref": "#/$defs/pushConfig"
        }
      }
    },
    "hooksManifest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "before_build": {
          "$ref": "#/$defs/stringArray"
        },
        "after_sign": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "testsManifest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "unit": {
          "$ref": "#/$defs/testTargetManifest"
        },
        "ui": {
          "$ref": "#/$defs/testTargetManifest"
        }
      }
    },
    "testTargetManifest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sources": {
          "$ref": "#/$defs/pathArray"
        }
      }
    }
  }
