{
  "$schema": "../../schemas/apple-app.v1.json",
  "name": "ExampleCompanionApp",
  "bundle_id": "dev.orbit.examples.watchapp",
  "version": "0.1.0",
  "build": 1,
  "platforms": {
    "ios": "18.0",
    "watchos": "11.0"
  },
  "sources": [
    "Sources/App"
  ],
  "watch": {
    "sources": [
      "Sources/WatchApp"
    ],
    "extension": {
      "sources": [
        "Sources/WatchExtension"
      ],
      "entry": {
        "class": "WatchExtensionDelegate"
      }
    }
  }
}
