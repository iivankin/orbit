{
  "name": "ExampleTVApp",
  "version": "0.1.0",
  "platform": "apple",
  "platforms": {
    "tvos": {
      "deployment_target": "18.0",
      "profiles": {
        "development": {
          "configuration": "debug",
          "distribution": "development"
        },
        "release": {
