{
  "$schema": "../../../../schemas/orbi-ui-test.v1.json",
  "appId": "dev.orbi.examples.macos",
  "name": "macos-drag-drop",
  "steps": [
    "launchApp",
    {
      "dragAndDrop": {
        "from": {
          "id": "drag-source"
        },
        "to": {
          "id": "drop-target"
        },
        "duration": "900ms",
        "delta": 4
      }
    },
    {
      "assertVisible": "Dropped orbi-token"
    },
    {
      "takeScreenshot": "macos-drag-drop"
    }
  ]
}
