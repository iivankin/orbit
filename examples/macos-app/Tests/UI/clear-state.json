{
  "$schema": "../../../../schemas/orbi-ui-test.v1.json",
  "appId": "dev.orbi.examples.macos",
  "name": "macos-clear-state",
  "steps": [
    "clearState",
    "launchApp",
    {
      "assertVisible": "Clean slate"
    },
    {
      "tapOn": {
        "id": "persist-state-button"
      }
    },
    {
      "assertVisible": "Persisted state restored"
    },
    "stopApp",
    "launchApp",
    {
      "assertVisible": "Persisted state restored"
    },
    "clearState",
    "launchApp",
    {
      "assertVisible": "Clean slate"
    },
    {
      "takeScreenshot": "macos-clear-state"
    }
  ]
}
