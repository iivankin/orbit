{
  "$schema": "../../../../schemas/orbit-ui-test.v1.json",
  "appId": "dev.orbit.examples.macos",
  "name": "macos-shortcut",
  "steps": [
    "launchApp",
    {
      "assertVisible": "Awaiting menu action"
    },
    {
      "pressKey": {
        "key": "K",
        "modifiers": ["COMMAND", "SHIFT"]
      }
    },
    {
      "assertVisible": "Menu action triggered"
    },
    {
      "takeScreenshot": "macos-shortcut"
    }
  ]
}
