{
  "$schema": "../../../../schemas/orbit-ui-test.v1.json",
  "appId": "dev.orbit.examples.macos",
  "name": "macos-scroll-command",
  "steps": [
    "launchApp",
    {
      "repeat": {
        "times": 4,
        "commands": [
          {
            "scroll": "DOWN"
          }
        ]
      }
    },
    {
      "assertVisible": {
        "id": "scroll-footer"
      }
    },
    {
      "takeScreenshot": "macos-scroll-command"
    }
  ]
}
