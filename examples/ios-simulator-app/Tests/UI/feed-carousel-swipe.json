{
  "$schema": "../../../../schemas/orbit-ui-test.v1.json",
  "appId": "dev.orbit.examples.exampleiosapp",
  "name": "Feed Carousel Swipe Demo",
  "steps": [
    "launchApp",
    {
      "tapOn": "Open Swipe Lab"
    },
    {
      "tapOn": "Feed Carousel"
    },
    {
      "assertVisible": "Feed Card One"
    },
    {
      "swipe": {
        "start": "90%, 45%",
        "end": "10%, 45%"
      }
    },
    {
      "swipe": {
        "start": "90%, 45%",
        "end": "10%, 45%"
      }
    },
    {
      "assertVisible": "Feed Card Three"
    },
    {
      "takeScreenshot": "feed-carousel-swipe"
    }
  ]
}
