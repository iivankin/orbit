{
  "$schema": "../../../../schemas/orbi-ui-test.v1.json",
  "appId": "dev.orbi.examples.exampleiosapp",
  "name": "Embedded Pager Swipe Demo",
  "steps": [
    "launchApp",
    {
      "tapOn": "Open Swipe Lab"
    },
    {
      "tapOn": "Embedded Pager Card"
    },
    {
      "assertVisible": "Embedded Pager Intro"
    },
    {
      "swipe": {
        "start": "85%, 45%",
        "end": "15%, 45%"
      }
    },
    {
      "assertVisible": "Embedded Pager Email"
    },
    {
      "takeScreenshot": "embedded-pager-swipe"
    }
  ]
}
