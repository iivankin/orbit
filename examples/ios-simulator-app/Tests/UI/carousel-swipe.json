{
  "$schema": "../../../../schemas/orbit-ui-test.v1.json",
  "appId": "dev.orbit.examples.exampleiosapp",
  "name": "Carousel Swipe Demo",
  "steps": [
    "launchApp",
    {
      "tapOn": "Open Swipe Lab"
    },
    {
      "tapOn": "Horizontal Card Carousel"
    },
    {
      "assertVisible": "Orion Card"
    },
    {
      "swipe": "LEFT"
    },
    {
      "swipe": "LEFT"
    },
    {
      "assertVisible": "Aurora Card"
    },
    {
      "takeScreenshot": "carousel-swipe"
    }
  ]
}
